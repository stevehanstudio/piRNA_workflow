Bootstrap: docker
From: eclipse-temurin:8-jre-jammy

%labels
    Maintainer HeLab
    Version 0.11.3
    Description FastQC 0.11.3 quality control tool for high throughput sequence data

%help
    FastQC 0.11.3 - Quality control tool for high throughput sequence data
    Matches the version used in the original Peng-He-Lab pipeline.
    
    Usage:
        apptainer run fastqc_0.11.3.sif input.fastq -o output_dir
        apptainer exec fastqc_0.11.3.sif fastqc input.fastq -o output_dir

%environment
    export PATH=/opt/FastQC:$PATH

%post
    # Install dependencies
    apt-get update && \
    apt-get install -y --no-install-recommends \
        wget \
        unzip \
        perl \
        ca-certificates && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    # Download and install FastQC 0.11.3 from Babraham Bioinformatics
    cd /opt
    wget -q https://www.bioinformatics.babraham.ac.uk/projects/fastqc/fastqc_v0.11.3.zip && \
    unzip -q fastqc_v0.11.3.zip && \
    rm fastqc_v0.11.3.zip && \
    chmod +x /opt/FastQC/fastqc

    # Create symlink for easy access
    ln -sf /opt/FastQC/fastqc /usr/local/bin/fastqc

%runscript
    exec /opt/FastQC/fastqc "$@"
