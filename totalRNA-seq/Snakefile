# Snakemake workflow for totalRNA-seq processing
# This workflow handles reads trimming and quality control

# Configuration
configfile: "config.yaml"

import os
import sys

# When PIPELINE_CONTAINER=1: all tools are in the container
PIPELINE_CONTAINER = os.environ.get("PIPELINE_CONTAINER") == "1"

# Use workflow.basedir (Snakefile dir) - __file__ can resolve to Snakemake package under conda run
try:
    SNAKEFILE_DIR = str(workflow.basedir)
except (NameError, AttributeError):
    SNAKEFILE_DIR = os.path.dirname(os.path.abspath(__file__))
PROJECT_ROOT = os.path.dirname(SNAKEFILE_DIR)
ABS_PROJECT_ROOT = os.path.abspath(PROJECT_ROOT)
ABS_SNAKEFILE_DIR = os.path.abspath(SNAKEFILE_DIR)

# ==============================================================================
# PATCHED BOWTIE CONFIGURATION (same as original Luo_2025_piRNA pipeline)
# ==============================================================================
if PIPELINE_CONTAINER:
    SAMTOOLS_018 = os.environ.get("SAMTOOLS_018", "/opt/pipeline/samtools-0.1.8/samtools")
    SAMTOOLS_016 = os.environ.get("SAMTOOLS_016", "/opt/pipeline/samtools-0.1.16/samtools")
    SAMTOOLS_SORT_CMD = SAMTOOLS_016
    SAMTOOLS_INDEX_CMD = SAMTOOLS_016
    BOWTIE_CMD = "bowtie"
    BOWTIE_BUILD_CMD = "bowtie-build"
    BOWTIE_CONTAINER = None
    BOWTIE_ENV = "envs/container_tools.yaml"  # patched bowtie (--sam-nh) in container PATH
    USE_BOWTIE_CONTAINER = False
    FASTQC_CMD = "fastqc"
    FASTQC_SIF = None
    FASTQC_ENV = "envs/container_tools.yaml"  # fastqc in container PATH
    CUTADAPT_CMD = "cutadapt"
    CUTADAPT_USE_CONTAINER = False
    CUTADAPT_SIF = None
    CUTADAPT_ENV = "envs/container_tools.yaml"  # cutadapt in container PATH
    TRIM_READS_ENV = "envs/container_tools.yaml"  # trimfastq.py uses Python from container
    STAR_ENV = "envs/container_tools.yaml"
    RSEM_ENV = "envs/container_tools.yaml"
    DEEPTOOLS_ENV = "envs/container_tools.yaml"
    print("INFO: Running in pipeline container - using container tools", file=sys.stderr)
else:
    PATCHED_BOWTIE_DIR = os.path.join(PROJECT_ROOT, "Shared", "Scripts", "bin")
    PATCHED_BOWTIE = os.path.join(PATCHED_BOWTIE_DIR, "bowtie")
    PATCHED_BOWTIE_BUILD = os.path.join(PATCHED_BOWTIE_DIR, "bowtie-build")
    BOWTIE_SIF = os.path.join(PROJECT_ROOT, "CHIP-seq", "envs", "bowtie_1.0.1_nh.sif")

    if os.path.exists(BOWTIE_SIF) and os.path.isfile(BOWTIE_SIF):
        BOWTIE_CMD = "bowtie"
        BOWTIE_BUILD_CMD = "bowtie-build"
        print("INFO: Using Bowtie 1.0.1-nh via Apptainer container", file=sys.stderr)
    elif os.path.exists(PATCHED_BOWTIE) and os.access(PATCHED_BOWTIE, os.X_OK):
        BOWTIE_CMD = PATCHED_BOWTIE
        BOWTIE_BUILD_CMD = PATCHED_BOWTIE_BUILD
        print(f"INFO: Using patched Bowtie: {BOWTIE_CMD}", file=sys.stderr)
    else:
        BOWTIE_CMD = "bowtie"
        BOWTIE_BUILD_CMD = "bowtie-build"
        print(f"WARNING: Patched Bowtie not found at {PATCHED_BOWTIE}, using conda bowtie", file=sys.stderr)

    USE_BOWTIE_CONTAINER = os.path.exists(BOWTIE_SIF) and os.path.isfile(BOWTIE_SIF)
    BOWTIE_CONTAINER = BOWTIE_SIF if USE_BOWTIE_CONTAINER else None
    BOWTIE_ENV = "envs/bowtie.yaml"  # used when not using bowtie container
    SAMTOOLS_SORT_CMD = "samtools"
    SAMTOOLS_INDEX_CMD = "samtools"

    FASTQC_SIF = os.path.join(PROJECT_ROOT, "CHIP-seq", "envs", "fastqc_0.11.3.sif")
    FASTQC_CMD = "fastqc"
    FASTQC_ENV = "envs/fastqc.yaml"  # used when not using fastqc container
    CUTADAPT_SIF = os.path.join(PROJECT_ROOT, "CHIP-seq", "envs", "cutadapt_1.8.3.sif")
    CUTADAPT_USE_CONTAINER = os.path.exists(CUTADAPT_SIF) and os.path.isfile(CUTADAPT_SIF)
    CUTADAPT_ENV = "envs/cutadapt.yaml"  # used when not using cutadapt container
    TRIM_READS_ENV = "envs/python.yaml"  # trimfastq.py needs Python 3
    CUTADAPT_CMD = "cutadapt"
    STAR_ENV = "envs/star.yaml"
    RSEM_ENV = "envs/rsem.yaml"
    DEEPTOOLS_ENV = "envs/deeptools.yaml"

# ==============================================================================
# BACKWARD COMPATIBILITY LAYER
# ==============================================================================
# Support both old-style and new-style (genome section) configuration formats
# If 'genome' section exists, use it; otherwise fall back to old config
# ==============================================================================

if "genome" in config:
    # New format - genome-agnostic configuration
    GENOME_VERSION = config["genome"]["version"]
    GENOME_SPECIES = config["genome"]["species"]
    RRNA_SPECIES = config["genome"]["rrna_species"]
    
    # Expand path templates
    GENOME_FASTA = config["genome"]["fasta"].format(version=GENOME_VERSION)
    GENOME_BOWTIE_INDEX = config["genome"]["bowtie_index"].format(version=GENOME_VERSION)
    GENOME_CHROM_SIZES = config["genome"]["chrom_sizes"].format(version=GENOME_VERSION)
    GENOME_GTF = config["genome"]["gtf"].format(version=GENOME_VERSION)
    RRNA_INDEX = config["genome"]["rrna_index"].format(rrna_species=RRNA_SPECIES)
    RRNA_FASTA = config["genome"]["rrna_fasta"].format(rrna_species=RRNA_SPECIES)
    
    # Derive genome directory and harmonized GTF path
    genome_dir = os.path.dirname(GENOME_FASTA)
    HARMONIZED_GTF = f"{genome_dir}/annotations/{GENOME_VERSION}_chr_harmonized.gtf"
    ORIGINAL_GTF = GENOME_GTF
    
    # Legacy names for compatibility
    DM6_REFERENCE = GENOME_FASTA
    RRNA_REFERENCE = RRNA_FASTA
else:
    # Old format - use legacy configuration
    GENOME_VERSION = "dm6"
    GENOME_SPECIES = "drosophila"
    RRNA_SPECIES = "dmel"
    
    DM6_REFERENCE = config.get("dm6_fasta", "../Shared/DataFiles/genomes/dm6.fa")
    RRNA_REFERENCE = config.get("rrna_fasta", "../Shared/DataFiles/genomes/rrna/dmel_rRNA_unit.fa")
    RRNA_INDEX = config.get("rrna_index", "../Shared/DataFiles/genomes/rrna/dmel_rRNA_unit")
    
    genome_dir = os.path.dirname(DM6_REFERENCE)
    ORIGINAL_GTF = config.get("original_gtf", f"{genome_dir}/annotations/dm6.gtf")
    HARMONIZED_GTF = config.get("harmonized_gtf", f"{genome_dir}/annotations/dm6_chr_harmonized.gtf")
    
    GENOME_FASTA = DM6_REFERENCE
    GENOME_GTF = ORIGINAL_GTF

# Shared file paths - centralized configuration
SHARED_SCRIPTS = "../Shared/Scripts"
SHARED_DATA = "../Shared/DataFiles"
SHARED_GENOME = f"{SHARED_DATA}/genome"

# Scripts
TRIMFASTQ_SCRIPT = config.get("trimfastq_script", f"{SHARED_SCRIPTS}/python/trimfastq.py")

# Vector files - read from config if available, otherwise use defaults
VECTOR_42AB_INDEX = config.get("vector_index", f"{SHARED_GENOME}/YichengVectors/42AB_UBIG")
VECTOR_42AB_REF = config.get("vector_ref", f"{SHARED_GENOME}/YichengVectors/42AB_UBIG.fa")

# Define input files
FASTQ_FILE = config["fastq_file"]
READ_LENGTH = config["read_length"]
FASTQC_VERSION = config["fastqc_version"]

# ==============================================================================
# OUTPUT FILE PREFIX (genome-agnostic)
# ==============================================================================
# Construct output prefix from genome version and read length
# Format: {version}.{read_length}mer (e.g., {OUTPUT_PREFIX}, hg38.75mer)
# This can be overridden in config.yaml with 'output_prefix' field
# ==============================================================================
if "output_prefix" in config:
    OUTPUT_PREFIX = config["output_prefix"].format(version=GENOME_VERSION, read_length=READ_LENGTH)
else:
    OUTPUT_PREFIX = f"{GENOME_VERSION}.{READ_LENGTH}mer"

# Define output directories
RESULTS_DIR = "results"
FASTQC_INITIAL_DIR = f"{RESULTS_DIR}/fastqc_initial"
FASTQC_TRIMMED_DIR = f"{RESULTS_DIR}/fastqc_trimmed"
TRIMMED_FASTQ = f"{RESULTS_DIR}/trimmed/allfastq{READ_LENGTH}"
CUTADAPT_DIR = f"{RESULTS_DIR}/cutadapt"
MAPPING_DIR = f"{RESULTS_DIR}/mapping"
RRNA_DIR = f"{RESULTS_DIR}/rrna_removal"
STAR_DIR = f"{RESULTS_DIR}/star_alignment"
VECTOR_DIR = f"{RESULTS_DIR}/vector_mapping"

# Rule all - defines the final outputs
rule all:
    input:
        f"{FASTQC_INITIAL_DIR}/all.50mers_fastqc.html",
        f"{FASTQC_TRIMMED_DIR}/allfastq{READ_LENGTH}_fastqc.html",
        f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted.bam",
        f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted.bam.bai",
        f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.dup.bam",
        f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.dup.bam.bai",
        # Optional visualization outputs (comment out if having issues)
        # f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoordSignal.Unique.str1.out.bg.bigWig",
        # f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoord.coverage",
        # rules.build_rsem_index.output.rsem_index,
        f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted.rsem.genes.results",
        f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.dup.10.bg4"

# Index building rules - these generate indexes from source files
rule build_vector_42AB_index:
    input:
        vector_fa = VECTOR_42AB_REF
    output:
        index_files = expand(f"{VECTOR_42AB_INDEX}.{{ext}}", ext=["1.ebwt", "2.ebwt", "3.ebwt", "4.ebwt", "rev.1.ebwt", "rev.2.ebwt"])
    container:
        BOWTIE_CONTAINER
    conda:
        BOWTIE_ENV
    shell:
        """
        mkdir -p $(dirname {VECTOR_42AB_INDEX})
        {BOWTIE_BUILD_CMD} {input.vector_fa} {VECTOR_42AB_INDEX}
        """

rule build_rrna_index:
    input:
        rrna_fa = RRNA_REFERENCE
    output:
        index_files = expand(f"{SHARED_GENOME}/rrna/dmel_rRNA_unit.{{ext}}", ext=["1.ebwt", "2.ebwt", "3.ebwt", "4.ebwt", "rev.1.ebwt", "rev.2.ebwt"])
    container:
        BOWTIE_CONTAINER
    conda:
        BOWTIE_ENV
    shell:
        """
        mkdir -p {SHARED_GENOME}/rrna
        {BOWTIE_BUILD_CMD} {input.rrna_fa} {SHARED_GENOME}/rrna/dmel_rRNA_unit
        """

# Chromosome name harmonization - fix Ensembl vs UCSC naming convention mismatch
rule harmonize_chromosome_names:
    input:
        original_gtf = ORIGINAL_GTF
    output:
        harmonized_gtf = HARMONIZED_GTF
    shell:
        """
        mkdir -p $(dirname {output.harmonized_gtf})
        # Add 'chr' prefix to chromosome names to match UCSC convention used in dm6.fa
        sed 's/^2L/chr2L/; s/^2R/chr2R/; s/^3L/chr3L/; s/^3R/chr3R/; s/^4/chr4/; s/^X/chrX/; s/^Y/chrY/; s/^mitochondrion_genome/chrM/' {input.original_gtf} > {output.harmonized_gtf}
        """

# Build STAR genome index with harmonized GTF annotations
rule build_star_index:
    input:
        genome_fa = DM6_REFERENCE,
        gtf = HARMONIZED_GTF
    output:
        index_files = expand(f"{SHARED_GENOME}/star-index/{{file}}", file=["genomeParameters.txt", "Genome", "SA", "SAindex"])
    conda:
        STAR_ENV
    params:
        index_dir = f"{SHARED_GENOME}/star-index"
    shell:
        """
        mkdir -p {params.index_dir}
        STAR --runMode genomeGenerate \
             --genomeDir {params.index_dir} \
             --genomeFastaFiles {input.genome_fa} \
             --sjdbGTFfile {input.gtf} \
             --runThreadN 8 \
             --genomeSAindexNbases 12
        """

rule build_rsem_index:
    input:
        genome_fa = DM6_REFERENCE,
        gtf = HARMONIZED_GTF
    output:
        rsem_index = f"{SHARED_GENOME}/rsem.grp"
    conda:
        RSEM_ENV
    shell:
        """
        rsem-prepare-reference --gtf {input.gtf} {input.genome_fa} {SHARED_GENOME}/rsem
        """

rule rsem_quantification:
    input:
        bam = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted.bam",
        rsem_index = rules.build_rsem_index.output.rsem_index
    output:
        genes = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted.rsem.genes.results",
        isoforms = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted.rsem.isoforms.results"
    params:
        output_prefix = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted.rsem"
    conda:
        RSEM_ENV
    shell:
        """
        mkdir -p {STAR_DIR}/temp
        rsem-calculate-expression --bam \
                                  --estimate-rspd \
                                  --seed 12345 \
                                  -p 8 \
                                  --no-bam-output \
                                  --temporary-folder {STAR_DIR}/temp \
                                  {input.bam} \
                                  {SHARED_GENOME}/rsem \
                                  {params.output_prefix}
        """

# Initial FastQC quality check
rule fastqc_initial:
    input:
        fastq = FASTQ_FILE
    output:
        html = f"{FASTQC_INITIAL_DIR}/all.50mers_fastqc.html",
        zip = f"{FASTQC_INITIAL_DIR}/all.50mers_fastqc.zip"
    container:
        FASTQC_SIF
    conda:
        FASTQC_ENV
    shell:
        "mkdir -p {FASTQC_INITIAL_DIR} && fastqc {input.fastq} -o {FASTQC_INITIAL_DIR} -k 6"

# Optional: Adapter trimming with cutadapt (if adapters are known)
if CUTADAPT_USE_CONTAINER:
    rule cutadapt_trim:
        input:
            fastq = FASTQ_FILE
        output:
            trimmed = f"{CUTADAPT_DIR}/all_cutadapt.fastq"
        container:
            CUTADAPT_SIF
        params:
            adapters = config.get("adapters", "")
        shell:
            "mkdir -p {CUTADAPT_DIR} && if [ -n '{params.adapters}' ]; then cutadapt -a {params.adapters} -o {output.trimmed} {input.fastq}; else cp {input.fastq} {output.trimmed}; fi"
else:
    rule cutadapt_trim:
        input:
            fastq = FASTQ_FILE
        output:
            trimmed = f"{CUTADAPT_DIR}/all_cutadapt.fastq"
        conda:
            CUTADAPT_ENV
        params:
            adapters = config.get("adapters", "")
        shell:
            "mkdir -p {CUTADAPT_DIR} && cutadapt -a {params.adapters} -o {output.trimmed} {input.fastq}" if params.adapters else "mkdir -p {CUTADAPT_DIR} && cp {input.fastq} {output.trimmed}"

# Read trimming to specified length (original pipeline uses trimfastq.py, not cutadapt)
if CUTADAPT_USE_CONTAINER:
    rule trim_reads:
        input:
            fastq = rules.cutadapt_trim.output.trimmed
        output:
            trimmed = TRIMMED_FASTQ
        container:
            CUTADAPT_SIF
        conda:
            TRIM_READS_ENV
        params:
            length = READ_LENGTH
        shell:
            "mkdir -p {RESULTS_DIR}/trimmed && python {TRIMFASTQ_SCRIPT} {input.fastq} {params.length} -stdout 2>/dev/null > {output.trimmed}"
else:
    rule trim_reads:
        input:
            fastq = rules.cutadapt_trim.output.trimmed
        output:
            trimmed = TRIMMED_FASTQ
        conda:
            TRIM_READS_ENV
        params:
            length = READ_LENGTH
        shell:
            "mkdir -p {RESULTS_DIR}/trimmed && python {TRIMFASTQ_SCRIPT} {input.fastq} {params.length} -stdout 2>/dev/null > {output.trimmed}"

# Final FastQC quality check on trimmed reads
    rule fastqc_trimmed:
        input:
            fastq = rules.trim_reads.output.trimmed
        output:
            html = f"{FASTQC_TRIMMED_DIR}/allfastq{READ_LENGTH}_fastqc.html",
            zip = f"{FASTQC_TRIMMED_DIR}/allfastq{READ_LENGTH}_fastqc.zip"
        container:
            FASTQC_SIF
        conda:
            FASTQC_ENV
        shell:
            "mkdir -p {FASTQC_TRIMMED_DIR} && fastqc {input.fastq} -o {FASTQC_TRIMMED_DIR} -k 6"

# Ribosomal RNA removal using bowtie
rule rrna_removal:
    input:
        fastq = rules.trim_reads.output.trimmed
    output:
        unmapped = f"{RRNA_DIR}/Unmapped50.fastq",
        mapped = f"{RRNA_DIR}/allfastq.rRNA.mapped50.map"
    container:
        BOWTIE_CONTAINER
    conda:
        BOWTIE_ENV
    params:
        threads = config.get("threads", 8),
        rrna_index = config.get("rrna_index", "dmel_rRNA_unit")
    shell:
        "mkdir -p {RRNA_DIR} && {BOWTIE_CMD} {params.rrna_index} -p {params.threads} -v 2 -k 1 --best -t --sam-nh -q {input.fastq} --un {output.unmapped} {output.mapped}"

# STAR alignment to transcriptome
rule star_alignment:
    input:
        fastq = rules.rrna_removal.output.unmapped,
        star_index = rules.build_star_index.output.index_files
    output:
        bam = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.bam",
        sorted_bam = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted.bam",
        sorted_bai = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted.bam.bai"
    conda:
        STAR_ENV
    params:
        threads = config.get("threads", 8),
        genome_dir = f"{SHARED_GENOME}/star-index",
        prefix = OUTPUT_PREFIX,
        sort_prefix = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted"  # samtools 0.1.x syntax
    shell:
        "mkdir -p {STAR_DIR} && STAR --genomeDir {params.genome_dir} --readFilesIn {input.fastq} --runThreadN {params.threads} --genomeLoad NoSharedMemory --outFilterMultimapNmax 1 --alignSJoverhangMin 8 --alignSJDBoverhangMin 1 --outFilterMismatchNmax 999 --outFilterMismatchNoverReadLmax 0.0 --alignIntronMin 20 --alignIntronMax 1000000 --alignMatesGapMax 1000000 --outSAMheaderCommentFile {STAR_DIR}/COfile.txt --outSAMheaderHD @HD VN:1.4 SO:coordinate --outSAMunmapped Within --outFilterType BySJout --outSAMattributes NH HI AS NM MD --outSAMtype BAM SortedByCoordinate --quantMode TranscriptomeSAM GeneCounts --sjdbScore 1 --limitBAMsortRAM 30000000000 --outFileNamePrefix {STAR_DIR}/{params.prefix} --outSAMstrandField intronMotif && samtools sort {output.bam} {params.sort_prefix} && samtools index {output.sorted_bam}"

# Vector mapping using patched bowtie (--sam-nh produces headerless SAM, needs conversion)
rule bowtie_vector_mapping:
    input:
        fastq = rules.rrna_removal.output.unmapped,
        vector_index_files = expand(f"{VECTOR_42AB_INDEX}.{{ext}}", ext=["1.ebwt", "2.ebwt", "3.ebwt", "4.ebwt", "rev.1.ebwt", "rev.2.ebwt"])
    output:
        sam = f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.sam",
        aligned_fastq = f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.fastq"
    container:
        BOWTIE_CONTAINER
    conda:
        BOWTIE_ENV
    params:
        threads = config.get("threads", 8),
        vector_index = VECTOR_42AB_INDEX,
        prefix = OUTPUT_PREFIX
    shell:
        """
        mkdir -p {VECTOR_DIR}
        {BOWTIE_CMD} {params.vector_index} -p {params.threads} --chunkmbs 1024 -v 0 -a -m 1 -t --sam-nh --best --strata -q {input.fastq} -k 1 --al {output.aligned_fastq} > {output.sam}
        """

rule samtools_view_vector:
    input:
        sam = f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.sam",
        reference = VECTOR_42AB_REF
    output:
        bam = f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.bam"
    container:
        BOWTIE_CONTAINER
    conda:
        BOWTIE_ENV
    shell:
        """
        python3 -c "
import sys
ref_file = '{input.reference}'
sam_file = '{input.sam}'

# Generate SAM header from reference (handles multi-fasta)
print('@HD\\tVN:1.0\\tSO:unsorted')
with open(ref_file) as f:
    current_name, current_seq = None, []
    for line in f:
        if line.startswith('>'):
            if current_name:
                print(f'@SQ\\tSN:{{current_name}}\\tLN:{{sum(len(s) for s in current_seq)}}')
            current_name = line[1:].strip().split()[0]
            current_seq = []
        else:
            current_seq.append(line.strip())
    if current_name:
        print(f'@SQ\\tSN:{{current_name}}\\tLN:{{sum(len(s) for s in current_seq)}}')

# Convert patched bowtie format (8 fields) to standard SAM (11 fields)
with open(sam_file) as f:
    for line in f:
        line = line.strip()
        if not line: continue
        fields = line.split('\\t')
        if len(fields) >= 6:
            qname, strand, rname, pos, seq, qual = fields[:6]
            flag = '16' if strand == '-' else '0'
            cigar = f'{{len(seq)}}M'
            print(f'{{qname}}\\t{{flag}}\\t{{rname}}\\t{{pos}}\\t255\\t{{cigar}}\\t*\\t0\\t0\\t{{seq}}\\t{{qual}}')
" | samtools view -F 4 -bT {input.reference} - > {output.bam}
        """

rule samtools_sort_index_vector:
    input:
        bam = f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.bam"
    output:
        sorted_bam = f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.dup.bam",
        bai = f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.dup.bam.bai"
    params:
        # Use prefix form (samtools 0.1.x in pipeline container) rather than -o (samtools 1.x)
        sort_prefix = f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.dup"
    container:
        BOWTIE_CONTAINER
    conda:
        BOWTIE_ENV
    shell:
        "mkdir -p {VECTOR_DIR} && {SAMTOOLS_SORT_CMD} sort {input.bam} {params.sort_prefix} && {SAMTOOLS_INDEX_CMD} index {output.sorted_bam}"

rule feature_counts:
    input:
        bam = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.toTranscriptome.out.sorted.bam",
        gtf = HARMONIZED_GTF
    output:
        counts = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.counts.txt"
    conda:
        "envs/subread.yaml"  # or "envs/htseq.yaml"
    shell:
        """
        mkdir -p {STAR_DIR}
        featureCounts -T 8 -a {input.gtf} -o {output.counts} {input.bam}
        """

rule generate_bedgraph:
    input:
        bam = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoord.out.bam"
    output:
        bg = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoordSignal.Unique.str1.out.bg",
        #bgc = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoordSignal.Unique.str1.out.bgc"
    params:
        prefix = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoord"
    conda:
        STAR_ENV
    shell:
        """
        STAR --runMode inputAlignmentsFromBAM \
             --inputBAMfile {input.bam} \
             --outWigType bedGraph \
             --outWigStrand Unstranded \
             --outFileNamePrefix {params.prefix}
        """

rule generate_coverage_profiles:
    input:
        gtf = HARMONIZED_GTF,
        bedgraph = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoordSignal.Unique.str1.out.bg"
        # bedgraph = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoordSignal.Unique.str1.out.bgc"
    output:
        coverage = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoord.coverage"
    conda:
        "envs/python.yaml"  # Ensure this environment has Python and the required script
    shell:
        """
        python {SHARED_SCRIPTS}/python/gene_coverage_wig_gtf.py \
            {input.gtf} \
            {input.bedgraph} \
            1000 \
            {output.coverage}
        """

rule generate_bigwig:
    input:
        bedgraph = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoordSignal.Unique.str1.out.bg",
        chrom_sizes = f"{SHARED_GENOME}/bowtie-indexes/dm6.chrom.sizes"
    output:
        bigwig = f"{STAR_DIR}/{OUTPUT_PREFIX}Aligned.sortedByCoordSignal.Unique.str1.out.bg.bigWig"
    conda:
        "envs/ucsc.yaml"  # Ensure this environment has wigToBigWig
    shell:
        """
        wigToBigWig -clip {input.bedgraph} {input.chrom_sizes} {output.bigwig}
        """

rule bam_coverage:
    input:
        bam = f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.dup.bam"
    output:
        bg4 = f"{VECTOR_DIR}/{OUTPUT_PREFIX}.UBIG.vectoronly.dup.10.bg4"
    conda:
        DEEPTOOLS_ENV
    shell:
        """
        bamCoverage -b {input.bam} \
                    -of bedgraph \
                    -bs 10 \
                    -o {output.bg4}
        """
