VECTOR_COV_PREFIX = f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.42AB_UASG.vectoronly"
VECTOR_BG_10 = f"{VECTOR_COV_PREFIX}.10.bg4"
VECTOR_BG_10_MINUS = f"{VECTOR_COV_PREFIX}.10.Minus.bg4"
VECTOR_BG_10_PLUS = f"{VECTOR_COV_PREFIX}.10.Plus.bg4"
VECTOR_BG_100 = f"{VECTOR_COV_PREFIX}.100.bg4"
VECTOR_BG_100_MINUS = f"{VECTOR_COV_PREFIX}.100.Minus.bg4"
VECTOR_BG_100_PLUS = f"{VECTOR_COV_PREFIX}.100.Plus.bg4"
VECTOR_BG_1000 = f"{VECTOR_COV_PREFIX}.1000.bg4"
VECTOR_BG_1000_MINUS = f"{VECTOR_COV_PREFIX}.1000.Minus.bg4"
VECTOR_BG_1000_PLUS = f"{VECTOR_COV_PREFIX}.1000.Plus.bg4"

VECTOR_BG_10_CHOP = f"{VECTOR_BG_10}.chopped.bg4"
VECTOR_BG_100_CHOP = f"{VECTOR_BG_100}.chopped.bg4"
VECTOR_BG_1000_CHOP = f"{VECTOR_BG_1000}.chopped.bg4"

VECTOR_EBWT_SUFFIXES = ("1.ebwt", "2.ebwt", "3.ebwt", "4.ebwt", "rev.1.ebwt", "rev.2.ebwt")
VECTOR_EBWT = [f"{VECTOR_INDEX}.{suf}" for suf in VECTOR_EBWT_SUFFIXES]

_te_cfg = config.get("genome", {}).get("te_regions")
TE_REGIONS = _te_cfg if isinstance(_te_cfg, dict) else {}

def normalize_te_region(region: str) -> str:
    """
    deepTools 2.4.2 expects --region in the form CHR[:START[:END]].
    The Luo 2025 markdown uses CHR:START-END, so accept that and normalize.
    """
    if not region:
        return region
    # Convert "chr:start-end" -> "chr:start:end"
    m = re.match(r"^([^:]+):(\d+)-(\d+)$", region)
    if m:
        return f"{m.group(1)}:{m.group(2)}:{m.group(3)}"
    return region


def te_cov_prefix(tag: str) -> str:
    return f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{tag}"


TE_TARGET_FILES = []
for _te_tag in TE_REGIONS:
    _tp = te_cov_prefix(_te_tag)
    for _te_bs in (10, 100, 1000):
        TE_TARGET_FILES.append(f"{_tp}.{_te_bs}.bg4")
        TE_TARGET_FILES.append(f"{_tp}.{_te_bs}.Minus.bg4")
        TE_TARGET_FILES.append(f"{_tp}.{_te_bs}.Plus.bg4")
        TE_TARGET_FILES.append(f"{_tp}.{_te_bs}.bg4.chopped.bg4")


