def resolve_existing_fastq(path_str: str):
    """
    Resolve fastq paths in a way that works both for:
    - config defaults (paths relative to this Snakefile directory)
    - run_workflow.sh overrides (paths often relative to project root)
    """
    def norm(p: str) -> str:
        return os.path.normpath(p)

    candidates = []
    if os.path.isabs(path_str):
        candidates.append(path_str)
    else:
        stripped = path_str
        if stripped.startswith("./"):
            stripped = stripped[2:]

        candidates.append(path_str)
        candidates.append(norm(str(SNAKEFILE_DIR / path_str)))
        candidates.append(norm(str(SNAKEFILE_DIR / stripped)))
        candidates.append(norm(str(PROJECT_ROOT / path_str)))
        candidates.append(norm(str(PROJECT_ROOT / stripped)))

    for c in candidates:
        if c and os.path.exists(c):
            return c
    return None


if isinstance(CONFIG_FASTQ, str) and CONFIG_FASTQ.startswith("./Shared/"):
    CONFIG_FASTQ = CONFIG_FASTQ.replace("./Shared/", "../Shared/", 1)

RAW_FASTQ = CONFIG_FASTQ


rule bootstrap_example_fastq:
    output:
        BOOTSTRAP_FASTQ
    shell:
        """
        mkdir -p {RESULTS_DIR}/bootstrap
        # 25 nt read; must pass size filter 23–29 for DAG smoke tests.
        printf '@read1\\nACGTACGTACGTACGTACGTACGTA\\n+\\nIIIIIIIIIIIIIIIIIIIIIIIII\\n' > {output}
        """


rule all:
    default_target: True
    input:
        _PI_RNA_ALL_INPUTS


rule bowtie_index_vector:
    input:
        VECTOR_FA,
    output:
        VECTOR_EBWT,
    params:
        prefix=VECTOR_INDEX,
    shell:
        """
        BBL="${{BOWTIE_BUILD_BIN:-bowtie-build}}"
        mkdir -p "$(dirname "{params.prefix}")"
        "$BBL" {input} {params.prefix}
        """


rule fastqc_raw:
    input:
        RAW_FASTQ,
    output:
        html=f"{QC_RAW_DIR}/{SAMPLE_NAME}_fastqc.html",
        zip=f"{QC_RAW_DIR}/{SAMPLE_NAME}_fastqc.zip",
    shell:
        """
        FC="${{FASTQC_BIN:-fastqc}}"
        mkdir -p {QC_RAW_DIR}
        "$FC" -o {QC_RAW_DIR} -k 6 {input}

        inbase="$(basename "{input}")"
        stem1="${{inbase%.gz}}"
        stem2="${{stem1%.fastq}}"
        stem3="${{stem1%.fq}}"
        src_html=""
        src_zip=""
        for s in "$inbase" "$stem1" "$stem2" "$stem3"; do
          if [[ -f "{QC_RAW_DIR}/${{s}}_fastqc.html" ]]; then
            src_html="{QC_RAW_DIR}/${{s}}_fastqc.html"
            src_zip="{QC_RAW_DIR}/${{s}}_fastqc.zip"
            break
          fi
        done
        if [[ -z "$src_html" ]]; then
          echo "FastQC output not found for input: {input}" >&2
          ls -1 "{QC_RAW_DIR}" >&2 || true
          exit 1
        fi
        mv -f "$src_html" "{output.html}"
        mv -f "$src_zip" "{output.zip}"
        """


rule trim_adapters:
    input:
        RAW_FASTQ,
    output:
        TRIMMED_FASTQ,
    params:
        adapter=ADAPTER,
    shell:
        """
        CA="${{CUTADAPT_BIN:-cutadapt}}"
        mkdir -p {RESULTS_DIR}/trimmed
        "$CA" -a {params.adapter} -m 15 -o {output} {input}
        """


rule size_select_pirna:
    input:
        TRIMMED_FASTQ,
    output:
        SIZE_SELECTED_FASTQ,
    params:
        min_len=MIN_LEN,
        max_len=MAX_LEN,
    shell:
        """
        CA="${{CUTADAPT_BIN:-cutadapt}}"
        "$CA" -m {params.min_len} -M {params.max_len} -o {output} {input}
        """


rule fastqc_filtered:
    input:
        SIZE_SELECTED_FASTQ,
    output:
        html=f"{QC_FILTERED_DIR}/{SAMPLE_NAME}.pirna_sized_fastqc.html",
        zip=f"{QC_FILTERED_DIR}/{SAMPLE_NAME}.pirna_sized_fastqc.zip",
    shell:
        """
        FC="${{FASTQC_BIN:-fastqc}}"
        mkdir -p {QC_FILTERED_DIR}
        "$FC" -o {QC_FILTERED_DIR} -k 6 {input}
        """


rule map_genome_align:
    input:
        fq=SIZE_SELECTED_FASTQ,
    output:
        bam=GENOME_BAM_RAW,
        al=GENOME_AL_FASTQ,
        un=GENOME_UN_FASTQ,
        multi=GENOME_MULTI_FASTQ,
    params:
        index=GENOME_INDEX,
        sortpfx=f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{GENOME_VERSION}.genome.sorttmp",
    threads:
        THREADS
    shell:
        """
        BT="${{BOWTIE_BIN:-bowtie}}"
        ST18="${{SAMTOOLS_018:-samtools}}"
        ST16="${{SAMTOOLS_016:-samtools}}"
        mkdir -p {RESULTS_DIR}/mapping
        "$BT" -p {threads} --chunkmbs 1024 -v 0 -a -m 1 -t --sam-nh --best --strata -q --sam -k 1 \
          --al {output.al} --un {output.un} --max {output.multi} \
          {params.index} {input.fq} \
          | "$ST18" view -bT {GENOME_FA} - \
          | "$ST16" sort - {params.sortpfx}
        mv -f "{params.sortpfx}.bam" "{output.bam}"
        """


rule remove_chrM:
    input:
        GENOME_BAM_RAW,
    output:
        bam=GENOME_BAM,
        bai=f"{GENOME_BAM}.bai",
    params:
        fa=GENOME_FA,
    shell:
        """
        ST18="${{SAMTOOLS_018:-samtools}}"
        ST16="${{SAMTOOLS_016:-samtools}}"
        "$ST16" view -h {input} | egrep -v "chrM" \
          | "$ST18" view -bT {params.fa} - > {output.bam}
        "$ST16" index {output.bam}
        """


rule filter_unique_genome_reads:
    input:
        GENOME_BAM,
    output:
        bam=UNIQUE_BAM,
        bai=f"{UNIQUE_BAM}.bai",
    params:
        mapq_flag=1 if MAPQ_FILTER_UNIQUE else 0,
    shell:
        """
        ST18="${{SAMTOOLS_018:-samtools}}"
        ST16="${{SAMTOOLS_016:-samtools}}"
        if [ {params.mapq_flag} -eq 1 ]; then
          "$ST18" view -b -q 1 {input} > {output.bam}
        else
          "$ST18" view -b {input} > {output.bam}
        fi
        "$ST16" index {output.bam}
        """


# Luo 2025 piRNA-seq.md: map the full 23–29 nt library to the vector index (not genome-unmapped only).
rule map_vectors:
    input:
        fq=SIZE_SELECTED_FASTQ,
        ebwt=VECTOR_EBWT,
    output:
        bam=VECTOR_BAM,
        bai=f"{VECTOR_BAM}.bai",
        al=VECTOR_AL_FASTQ,
    params:
        index=VECTOR_INDEX,
        sortpfx=f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.vector.sorttmp",
    threads:
        THREADS
    shell:
        """
        BT="${{BOWTIE_BIN:-bowtie}}"
        ST18="${{SAMTOOLS_018:-samtools}}"
        ST16="${{SAMTOOLS_016:-samtools}}"
        mkdir -p {RESULTS_DIR}/mapping
        "$BT" -p {threads} --chunkmbs 1024 -v 0 -a -m 1 -t --sam-nh --best --strata -q --sam -k 1 \
          --al {output.al} \
          {params.index} {input.fq} \
          | "$ST18" view -bT {VECTOR_FA} - \
          | "$ST16" sort - {params.sortpfx}
        mv -f "{params.sortpfx}.bam" "{output.bam}"
        "$ST16" index {output.bam}
        """


rule coverage:
    input:
        UNIQUE_BAM,
    output:
        COVERAGE_BG,
    params:
        chrom_sizes=CHROM_SIZES,
    shell:
        """
        BCV="${{BAMCOVERAGE_BIN:-bamCoverage}}"
        mkdir -p {RESULTS_DIR}/coverage
        "$BCV" --binSize 10 --outFileFormat bedgraph --bam {input} -o {output}
        """


rule vector_coverage:
    input:
        VECTOR_BAM
    output:
        bg10=VECTOR_BG_10,
        bg10m=VECTOR_BG_10_MINUS,
        bg10p=VECTOR_BG_10_PLUS,
        bg100=VECTOR_BG_100,
        bg100m=VECTOR_BG_100_MINUS,
        bg100p=VECTOR_BG_100_PLUS,
        bg1000=VECTOR_BG_1000,
        bg1000m=VECTOR_BG_1000_MINUS,
        bg1000p=VECTOR_BG_1000_PLUS,
    shell:
        """
        BCV="${{BAMCOVERAGE_BIN:-bamCoverage}}"
        mkdir -p {RESULTS_DIR}/coverage

        "$BCV" -b {input} -of bedgraph -bs 10 -o {output.bg10}
        "$BCV" -b {input} -of bedgraph -bs 10 --samFlagInclude 16 -o {output.bg10m}
        "$BCV" -b {input} -of bedgraph -bs 10 --samFlagExclude 16 -o {output.bg10p}

        "$BCV" -b {input} -of bedgraph -bs 100 -o {output.bg100}
        "$BCV" -b {input} -of bedgraph -bs 100 --samFlagInclude 16 -o {output.bg100m}
        "$BCV" -b {input} -of bedgraph -bs 100 --samFlagExclude 16 -o {output.bg100p}

        "$BCV" -b {input} -of bedgraph -bs 1000 -o {output.bg1000}
        "$BCV" -b {input} -of bedgraph -bs 1000 --samFlagInclude 16 -o {output.bg1000m}
        "$BCV" -b {input} -of bedgraph -bs 1000 --samFlagExclude 16 -o {output.bg1000p}
        """


rule chop_vector_bg4:
    input:
        bg4=lambda wc: [VECTOR_BG_10, VECTOR_BG_100, VECTOR_BG_1000]
    output:
        ch10=VECTOR_BG_10_CHOP,
        ch100=VECTOR_BG_100_CHOP,
        ch1000=VECTOR_BG_1000_CHOP,
    shell:
        r"""
        # Luo 2025: convert bg4 -> bed5, chop to bin size, then bedmap scores back.
        # Requires bedops/bedmap (bedops package) inside the pipeline container.
        BOPS="${{BEDOPS_BIN:-bedops}}"
        BMAP="${{BEDMAP_BIN:-bedmap}}"
        if ! command -v "$BOPS" >/dev/null 2>&1; then
          echo "Missing required tool: bedops" >&2
          echo "Rebuild container after pulling latest containers/pipeline.def:" >&2
          echo "  apptainer build containers/pirna_pipeline.sif containers/pipeline.def" >&2
          exit 127
        fi
        if ! command -v "$BMAP" >/dev/null 2>&1; then
          echo "Missing required tool: bedmap" >&2
          echo "Rebuild container after pulling latest containers/pipeline.def:" >&2
          echo "  apptainer build containers/pirna_pipeline.sif containers/pipeline.def" >&2
          exit 127
        fi
        for bs in 10 100 1000; do
          in="{VECTOR_COV_PREFIX}.${{bs}}.bg4"
          out="$in.chopped.bg4"
          tmp="$(mktemp -p {RESULTS_DIR}/coverage signal.XXXXXX.bed)"
          awk -vOFS="\t" '{{ print $1, $2, $3, ".", $4 }}' "$in" > "$tmp"
          "$BOPS" --chop "$bs" "$tmp" | "$BMAP" --echo --echo-map-score - "$tmp" | sed -e 's/|/\t/g' > "$out"
          rm -f "$tmp"
        done
        test -s "{output.ch10}" && test -s "{output.ch100}" && test -s "{output.ch1000}"
        """


if TE_REGIONS:
    _TE_TAG_PATTERN = "|".join(re.escape(k) for k in TE_REGIONS.keys())

    rule te_cluster_coverage:
        input:
            UNIQUE_BAM,
        output:
            bg10=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.10.bg4",
            bg10m=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.10.Minus.bg4",
            bg10p=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.10.Plus.bg4",
            bg100=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.100.bg4",
            bg100m=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.100.Minus.bg4",
            bg100p=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.100.Plus.bg4",
            bg1000=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.1000.bg4",
            bg1000m=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.1000.Minus.bg4",
            bg1000p=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.1000.Plus.bg4",
        wildcard_constraints:
            tag=_TE_TAG_PATTERN,
        params:
            region=lambda w: normalize_te_region(TE_REGIONS[w.tag]),
        shell:
            """
            BCV="${{BAMCOVERAGE_BIN:-bamCoverage}}"
            mkdir -p {RESULTS_DIR}/coverage
            REG='{params.region}'
            "$BCV" -b {input} -of bedgraph -bs 10 --region "$REG" -o {output.bg10}
            "$BCV" -b {input} -of bedgraph -bs 10 --region "$REG" --samFlagInclude 16 -o {output.bg10m}
            "$BCV" -b {input} -of bedgraph -bs 10 --region "$REG" --samFlagExclude 16 -o {output.bg10p}
            "$BCV" -b {input} -of bedgraph -bs 100 --region "$REG" -o {output.bg100}
            "$BCV" -b {input} -of bedgraph -bs 100 --region "$REG" --samFlagInclude 16 -o {output.bg100m}
            "$BCV" -b {input} -of bedgraph -bs 100 --region "$REG" --samFlagExclude 16 -o {output.bg100p}
            "$BCV" -b {input} -of bedgraph -bs 1000 --region "$REG" -o {output.bg1000}
            "$BCV" -b {input} -of bedgraph -bs 1000 --region "$REG" --samFlagInclude 16 -o {output.bg1000m}
            "$BCV" -b {input} -of bedgraph -bs 1000 --region "$REG" --samFlagExclude 16 -o {output.bg1000p}
            """

    rule chop_te_bg4:
        input:
            bg10=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.10.bg4",
            bg100=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.100.bg4",
            bg1000=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.1000.bg4",
        output:
            ch10=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.10.bg4.chopped.bg4",
            ch100=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.100.bg4.chopped.bg4",
            ch1000=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.23_29mer.te.{{tag}}.1000.bg4.chopped.bg4",
        wildcard_constraints:
            tag=_TE_TAG_PATTERN,
        params:
            prefix=lambda w: te_cov_prefix(w.tag),
        shell:
            r"""
            BOPS="${{BEDOPS_BIN:-bedops}}"
            BMAP="${{BEDMAP_BIN:-bedmap}}"
            if ! command -v "$BOPS" >/dev/null 2>&1; then
              echo "Missing required tool: bedops" >&2
              exit 127
            fi
            if ! command -v "$BMAP" >/dev/null 2>&1; then
              echo "Missing required tool: bedmap" >&2
              exit 127
            fi
            for bs in 10 100 1000; do
              in="{params.prefix}.$bs.bg4"
              out="$in.chopped.bg4"
              tmp="$(mktemp -p {RESULTS_DIR}/coverage te_signal.XXXXXX.bed)"
              awk -vOFS="\t" '{{ print $1, $2, $3, ".", $4 }}' "$in" > "$tmp"
              "$BOPS" --chop "$bs" "$tmp" | "$BMAP" --echo --echo-map-score - "$tmp" | sed -e 's/|/\t/g' > "$out"
              rm -f "$tmp"
            done
            test -s "{output.ch10}" && test -s "{output.ch100}" && test -s "{output.ch1000}"
            """


rule summary_report:
    input:
        genome_bam=GENOME_BAM,
        unique_bam=UNIQUE_BAM,
        vector_bam=VECTOR_BAM,
        coverage=COVERAGE_BG,
    output:
        SUMMARY_TXT,
    params:
        mapq_filter=MAPQ_FILTER_UNIQUE,
        te_note=",".join(sorted(TE_REGIONS.keys())) if TE_REGIONS else "none",
    shell:
        """
        mkdir -p {RESULTS_DIR}/reports
        {{
          echo "piRNA-seq summary (Luo 2025 piRNA-seq.md parity targets)"
          echo "sample: {SAMPLE_NAME}"
          echo "genome: {GENOME_VERSION}"
          echo "mapq_filter_unique: {params.mapq_filter}"
          echo "te_regions: {params.te_note}"
          echo "raw_fastq: {RAW_FASTQ}"
          echo "sized_fastq: {SIZE_SELECTED_FASTQ}"
          echo "genome_bam: {input.genome_bam}"
          echo "unique_bam: {input.unique_bam}"
          echo "vector_bam: {input.vector_bam}"
          echo "coverage_bedgraph: {input.coverage}"
        }} > {output}
        """
