configfile: "config.yaml"

import os
import pathlib
import re

SNAKEFILE_DIR = pathlib.Path(__file__).resolve().parent
PROJECT_ROOT = SNAKEFILE_DIR.parent

GENOME_VERSION = config["genome"]["version"]
SAMPLE_NAME = config["sample"]["name"]
THREADS = int(config["analysis"]["threads"])
RESULTS_DIR = config["output"]["results_dir"]
EMIT_COVERAGE = bool(config["analysis"].get("emit_coverage", False))
MAPQ_FILTER_UNIQUE = bool(config["analysis"].get("mapq_filter_unique", True))

CONFIG_FASTQ = config["sample"]["fastq"]
ADAPTER = config["references"]["adapter_sequence"]
GENOME_INDEX = config["genome"]["bowtie_index"].format(version=GENOME_VERSION)
GENOME_FA = config["genome"]["fasta"].format(version=GENOME_VERSION)
CHROM_SIZES = config["genome"]["chrom_sizes"].format(version=GENOME_VERSION)

MIN_LEN = int(config["analysis"]["min_read_length"])
MAX_LEN = int(config["analysis"]["max_read_length"])
_scfg = config["analysis"].get("size_class")
SIZE_CLASS = (
    str(_scfg).strip()
    if _scfg is not None and str(_scfg).strip()
    else f"{MIN_LEN}_{MAX_LEN}"
)
# Luo coverage filenames used "*23_29mer*"; keep the same pattern for arbitrary size_class.
SIZE_CLASS_MER = f"{SIZE_CLASS}mer"

VECTOR_EBWT_SUFFIXES = ("1.ebwt", "2.ebwt", "3.ebwt", "4.ebwt", "rev.1.ebwt", "rev.2.ebwt")


def _parse_vector_entries(ref: dict) -> list:
    """Build [{id, index}, ...] from references.vectors or legacy references.vector_index."""
    entries = []
    if ref.get("vectors"):
        for i, item in enumerate(ref["vectors"]):
            if not isinstance(item, dict):
                raise ValueError(f"references.vectors[{i}] must be a mapping with id and index")
            vid = str(item.get("id", "")).strip()
            idx = str(item.get("index", "")).strip()
            if not vid or not idx:
                raise ValueError(f"references.vectors[{i}] requires non-empty id and index")
            if not re.match(r"^[\w.-]+$", vid):
                raise ValueError(
                    f"Vector id {vid!r} must use only letters, digits, underscore, dot, hyphen"
                )
            entries.append({"id": vid, "index": idx})
    elif ref.get("vector_index"):
        idx = str(ref["vector_index"]).strip()
        vid = os.path.basename(os.path.normpath(idx))
        entries.append({"id": vid, "index": idx})
    else:
        raise ValueError("references must define vector_index (single) or vectors (non-empty list)")
    ids = [e["id"] for e in entries]
    if len(ids) != len(set(ids)):
        raise ValueError(f"Duplicate vector ids: {ids}")
    return entries


VECTOR_ENTRIES = _parse_vector_entries(config["references"])
VECTOR_IDS = [e["id"] for e in VECTOR_ENTRIES]
VECTOR_BY_ID = {e["id"]: e for e in VECTOR_ENTRIES}
_VECTOR_ID_PATTERN = "|".join(re.escape(v) for v in VECTOR_IDS)


def vector_index_prefix(vid: str) -> str:
    return VECTOR_BY_ID[vid]["index"]


def vector_fa_path(vid: str) -> str:
    return f"{vector_index_prefix(vid)}.fa"


def vector_built_prefix(vid: str) -> str:
    """Bowtie index prefix under results (Snakemake wildcards require stable paths)."""
    return f"{RESULTS_DIR}/references/vector/{vid}/bowtie"


def vector_bam_path(vid: str) -> str:
    return f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{vid}.vector.bam"


def vector_al_fastq_path(vid: str) -> str:
    return f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{vid}.vectoronly.fastq"


def vector_cov_prefix_for(vid: str) -> str:
    return f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{vid}.vectoronly"


QC_RAW_DIR = f"{RESULTS_DIR}/fastqc_raw"
QC_FILTERED_DIR = f"{RESULTS_DIR}/fastqc_filtered"
TRIMMED_FASTQ = f"{RESULTS_DIR}/trimmed/{SAMPLE_NAME}.adapter_trimmed.fastq"
SIZE_SELECTED_FASTQ = f"{RESULTS_DIR}/trimmed/{SAMPLE_NAME}.pirna_sized.fastq"
GENOME_BAM_RAW = f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{GENOME_VERSION}.genome.aln.bam"
GENOME_BAM = f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{GENOME_VERSION}.genome.bam"
UNIQUE_BAM = f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{GENOME_VERSION}.genome.unique.bam"
COVERAGE_BG = f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{SIZE_CLASS}.{GENOME_VERSION}.10bp.bg4"
SUMMARY_TXT = f"{RESULTS_DIR}/reports/{SAMPLE_NAME}.summary.txt"
BOOTSTRAP_FASTQ = f"{RESULTS_DIR}/bootstrap/{SAMPLE_NAME}.fastq"

# Parity artifacts from Luo 2025 piRNA-seq.md Bowtie steps
GENOME_AL_FASTQ = f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{GENOME_VERSION}.genome.unique.fastq"
GENOME_UN_FASTQ = f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{GENOME_VERSION}.genome.unmapped.fastq"
GENOME_MULTI_FASTQ = f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{GENOME_VERSION}.genome.multi.fastq"

# Coverage parity artifacts (Luo 2025): bins 10/100/1000 and strand splits, per vector id.
VECTOR_COVERAGE_ALL = []
if EMIT_COVERAGE:
    for _vid in VECTOR_IDS:
        _vp = vector_cov_prefix_for(_vid)
        for _bs in (10, 100, 1000):
            VECTOR_COVERAGE_ALL.append(f"{_vp}.{_bs}.bg4")
            VECTOR_COVERAGE_ALL.append(f"{_vp}.{_bs}.Minus.bg4")
            VECTOR_COVERAGE_ALL.append(f"{_vp}.{_bs}.Plus.bg4")
            VECTOR_COVERAGE_ALL.append(f"{_vp}.{_bs}.bg4.chopped.bg4")

_te_cfg = config.get("genome", {}).get("te_regions")
TE_REGIONS = _te_cfg if isinstance(_te_cfg, dict) else {}

def normalize_te_region(region: str) -> str:
    """
    deepTools 2.4.2 expects --region in the form CHR[:START[:END]].
    The Luo 2025 markdown uses CHR:START-END, so accept that and normalize.
    """
    if not region:
        return region
    # Convert "chr:start-end" -> "chr:start:end"
    m = re.match(r"^([^:]+):(\d+)-(\d+)$", region)
    if m:
        return f"{m.group(1)}:{m.group(2)}:{m.group(3)}"
    return region


def te_cov_prefix(tag: str) -> str:
    return f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{tag}"


TE_TARGET_FILES = []
if EMIT_COVERAGE:
    for _te_tag in TE_REGIONS:
        _tp = te_cov_prefix(_te_tag)
        for _te_bs in (10, 100, 1000):
            TE_TARGET_FILES.append(f"{_tp}.{_te_bs}.bg4")
            TE_TARGET_FILES.append(f"{_tp}.{_te_bs}.Minus.bg4")
            TE_TARGET_FILES.append(f"{_tp}.{_te_bs}.Plus.bg4")
            TE_TARGET_FILES.append(f"{_tp}.{_te_bs}.bg4.chopped.bg4")


_PI_RNA_ALL_INPUTS = [
    f"{QC_RAW_DIR}/{SAMPLE_NAME}_fastqc.html",
    f"{QC_FILTERED_DIR}/{SAMPLE_NAME}.pirna_sized_fastqc.html",
    TRIMMED_FASTQ,
    SIZE_SELECTED_FASTQ,
    GENOME_BAM,
    f"{GENOME_BAM}.bai",
    UNIQUE_BAM,
    f"{UNIQUE_BAM}.bai",
    GENOME_AL_FASTQ,
    GENOME_UN_FASTQ,
    GENOME_MULTI_FASTQ,
    SUMMARY_TXT,
]
for _vid in VECTOR_IDS:
    _PI_RNA_ALL_INPUTS.extend(
        [
            vector_bam_path(_vid),
            f"{vector_bam_path(_vid)}.bai",
            vector_al_fastq_path(_vid),
        ]
    )
_PI_RNA_ALL_INPUTS.extend(TE_TARGET_FILES)

if EMIT_COVERAGE:
    _PI_RNA_ALL_INPUTS.extend([COVERAGE_BG] + VECTOR_COVERAGE_ALL)


def resolve_existing_fastq(path_str: str):
    """
    Resolve fastq paths in a way that works both for:
    - config defaults (paths relative to this Snakefile directory)
    - run_workflow.sh overrides (paths often relative to project root)
    """
    def norm(p: str) -> str:
        return os.path.normpath(p)

    candidates = []
    if os.path.isabs(path_str):
        candidates.append(path_str)
    else:
        stripped = path_str
        if stripped.startswith("./"):
            stripped = stripped[2:]

        candidates.append(path_str)
        candidates.append(norm(str(SNAKEFILE_DIR / path_str)))
        candidates.append(norm(str(SNAKEFILE_DIR / stripped)))
        candidates.append(norm(str(PROJECT_ROOT / path_str)))
        candidates.append(norm(str(PROJECT_ROOT / stripped)))

    for c in candidates:
        if c and os.path.exists(c):
            return c
    return None


if isinstance(CONFIG_FASTQ, str) and CONFIG_FASTQ.startswith("./Shared/"):
    CONFIG_FASTQ = CONFIG_FASTQ.replace("./Shared/", "../Shared/", 1)

RAW_FASTQ = CONFIG_FASTQ


rule bootstrap_example_fastq:
    output:
        BOOTSTRAP_FASTQ
    shell:
        """
        mkdir -p {RESULTS_DIR}/bootstrap
        # 25 nt read; must pass size filter 23–29 for DAG smoke tests.
        printf '@read1\\nACGTACGTACGTACGTACGTACGTA\\n+\\nIIIIIIIIIIIIIIIIIIIIIIIII\\n' > {output}
        """


rule all:
    default_target: True
    input:
        _PI_RNA_ALL_INPUTS


rule bowtie_index_vector:
    input:
        fa=lambda wc: vector_fa_path(wc.vector_id),
    output:
        ebwt=expand(
            RESULTS_DIR + "/references/vector/{{vector_id}}/bowtie.{suf}",
            suf=VECTOR_EBWT_SUFFIXES,
        ),
    params:
        prefix=lambda wc: vector_built_prefix(wc.vector_id),
    wildcard_constraints:
        vector_id=_VECTOR_ID_PATTERN,
    shell:
        """
        BBL="${{BOWTIE_BUILD_BIN:-bowtie-build}}"
        mkdir -p "$(dirname "{params.prefix}")"
        "$BBL" {input.fa} {params.prefix}
        """


rule fastqc_raw:
    input:
        RAW_FASTQ,
    output:
        html=f"{QC_RAW_DIR}/{SAMPLE_NAME}_fastqc.html",
        zip=f"{QC_RAW_DIR}/{SAMPLE_NAME}_fastqc.zip",
    shell:
        """
        FC="${{FASTQC_BIN:-fastqc}}"
        mkdir -p {QC_RAW_DIR}
        "$FC" -o {QC_RAW_DIR} -k 6 {input}

        inbase="$(basename "{input}")"
        stem1="${{inbase%.gz}}"
        stem2="${{stem1%.fastq}}"
        stem3="${{stem1%.fq}}"
        src_html=""
        src_zip=""
        for s in "$inbase" "$stem1" "$stem2" "$stem3"; do
          if [[ -f "{QC_RAW_DIR}/${{s}}_fastqc.html" ]]; then
            src_html="{QC_RAW_DIR}/${{s}}_fastqc.html"
            src_zip="{QC_RAW_DIR}/${{s}}_fastqc.zip"
            break
          fi
        done
        if [[ -z "$src_html" ]]; then
          echo "FastQC output not found for input: {input}" >&2
          ls -1 "{QC_RAW_DIR}" >&2 || true
          exit 1
        fi
        mv -f "$src_html" "{output.html}"
        mv -f "$src_zip" "{output.zip}"
        """


rule trim_adapters:
    input:
        RAW_FASTQ,
    output:
        TRIMMED_FASTQ,
    params:
        adapter=ADAPTER,
    shell:
        """
        CA="${{CUTADAPT_BIN:-cutadapt}}"
        mkdir -p {RESULTS_DIR}/trimmed
        "$CA" -a {params.adapter} -m 15 -o {output} {input}
        """


rule size_select_pirna:
    input:
        TRIMMED_FASTQ,
    output:
        SIZE_SELECTED_FASTQ,
    params:
        min_len=MIN_LEN,
        max_len=MAX_LEN,
    shell:
        """
        CA="${{CUTADAPT_BIN:-cutadapt}}"
        "$CA" -m {params.min_len} -M {params.max_len} -o {output} {input}
        """


rule fastqc_filtered:
    input:
        SIZE_SELECTED_FASTQ,
    output:
        html=f"{QC_FILTERED_DIR}/{SAMPLE_NAME}.pirna_sized_fastqc.html",
        zip=f"{QC_FILTERED_DIR}/{SAMPLE_NAME}.pirna_sized_fastqc.zip",
    shell:
        """
        FC="${{FASTQC_BIN:-fastqc}}"
        mkdir -p {QC_FILTERED_DIR}
        "$FC" -o {QC_FILTERED_DIR} -k 6 {input}
        """


rule map_genome_align:
    input:
        fq=SIZE_SELECTED_FASTQ,
    output:
        bam=GENOME_BAM_RAW,
        al=GENOME_AL_FASTQ,
        un=GENOME_UN_FASTQ,
        multi=GENOME_MULTI_FASTQ,
    params:
        index=GENOME_INDEX,
        sortpfx=f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{GENOME_VERSION}.genome.sorttmp",
    threads:
        THREADS
    shell:
        """
        BT="${{BOWTIE_BIN:-bowtie}}"
        ST18="${{SAMTOOLS_018:-samtools}}"
        ST16="${{SAMTOOLS_016:-samtools}}"
        mkdir -p {RESULTS_DIR}/mapping
        "$BT" -p {threads} --chunkmbs 1024 -v 0 -a -m 1 -t --sam-nh --best --strata -q --sam -k 1 \
          --al {output.al} --un {output.un} --max {output.multi} \
          {params.index} {input.fq} \
          | "$ST18" view -bT {GENOME_FA} - \
          | "$ST16" sort - {params.sortpfx}
        mv -f "{params.sortpfx}.bam" "{output.bam}"
        """


rule remove_chrM:
    input:
        GENOME_BAM_RAW,
    output:
        bam=GENOME_BAM,
        bai=f"{GENOME_BAM}.bai",
    params:
        fa=GENOME_FA,
    shell:
        """
        ST18="${{SAMTOOLS_018:-samtools}}"
        ST16="${{SAMTOOLS_016:-samtools}}"
        "$ST16" view -h {input} | egrep -v "chrM" \
          | "$ST18" view -bT {params.fa} - > {output.bam}
        "$ST16" index {output.bam}
        """


rule filter_unique_genome_reads:
    input:
        GENOME_BAM,
    output:
        bam=UNIQUE_BAM,
        bai=f"{UNIQUE_BAM}.bai",
    params:
        mapq_flag=1 if MAPQ_FILTER_UNIQUE else 0,
    shell:
        """
        ST18="${{SAMTOOLS_018:-samtools}}"
        ST16="${{SAMTOOLS_016:-samtools}}"
        if [ {params.mapq_flag} -eq 1 ]; then
          "$ST18" view -b -q 1 {input} > {output.bam}
        else
          "$ST18" view -b {input} > {output.bam}
        fi
        "$ST16" index {output.bam}
        """


# Luo 2025 piRNA-seq.md: map the full size-selected library to each vector index (not genome-unmapped only).
rule map_vectors:
    input:
        fq=SIZE_SELECTED_FASTQ,
        ebwt=expand(
            RESULTS_DIR + "/references/vector/{{vector_id}}/bowtie.{suf}",
            suf=VECTOR_EBWT_SUFFIXES,
        ),
    output:
        bam=f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{{vector_id}}.vector.bam",
        bai=f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{{vector_id}}.vector.bam.bai",
        al=f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{{vector_id}}.vectoronly.fastq",
    params:
        index=lambda wc: vector_built_prefix(wc.vector_id),
        fa=lambda wc: vector_fa_path(wc.vector_id),
        sortpfx=f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{{vector_id}}.vector.sorttmp",
    threads:
        THREADS
    wildcard_constraints:
        vector_id=_VECTOR_ID_PATTERN,
    shell:
        """
        BT="${{BOWTIE_BIN:-bowtie}}"
        ST18="${{SAMTOOLS_018:-samtools}}"
        ST16="${{SAMTOOLS_016:-samtools}}"
        mkdir -p {RESULTS_DIR}/mapping
        "$BT" -p {threads} --chunkmbs 1024 -v 0 -a -m 1 -t --sam-nh --best --strata -q --sam -k 1 \
          --al {output.al} \
          {params.index} {input.fq} \
          | "$ST18" view -bT {params.fa} - \
          | "$ST16" sort - {params.sortpfx}
        mv -f "{params.sortpfx}.bam" "{output.bam}"
        "$ST16" index {output.bam}
        """


rule coverage:
    input:
        UNIQUE_BAM,
    output:
        COVERAGE_BG,
    params:
        chrom_sizes=CHROM_SIZES,
    shell:
        """
        BCV="${{BAMCOVERAGE_BIN:-bamCoverage}}"
        mkdir -p {RESULTS_DIR}/coverage
        "$BCV" --binSize 10 --outFileFormat bedgraph --bam {input} -o {output}
        """


rule vector_coverage:
    input:
        bam=f"{RESULTS_DIR}/mapping/{SAMPLE_NAME}.{SIZE_CLASS}.{{vector_id}}.vector.bam",
    output:
        bg10=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.10.bg4",
        bg10m=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.10.Minus.bg4",
        bg10p=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.10.Plus.bg4",
        bg100=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.100.bg4",
        bg100m=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.100.Minus.bg4",
        bg100p=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.100.Plus.bg4",
        bg1000=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.1000.bg4",
        bg1000m=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.1000.Minus.bg4",
        bg1000p=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.1000.Plus.bg4",
    wildcard_constraints:
        vector_id=_VECTOR_ID_PATTERN,
    shell:
        """
        BCV="${{BAMCOVERAGE_BIN:-bamCoverage}}"
        mkdir -p {RESULTS_DIR}/coverage

        "$BCV" -b {input.bam} -of bedgraph -bs 10 -o {output.bg10}
        "$BCV" -b {input.bam} -of bedgraph -bs 10 --samFlagInclude 16 -o {output.bg10m}
        "$BCV" -b {input.bam} -of bedgraph -bs 10 --samFlagExclude 16 -o {output.bg10p}

        "$BCV" -b {input.bam} -of bedgraph -bs 100 -o {output.bg100}
        "$BCV" -b {input.bam} -of bedgraph -bs 100 --samFlagInclude 16 -o {output.bg100m}
        "$BCV" -b {input.bam} -of bedgraph -bs 100 --samFlagExclude 16 -o {output.bg100p}

        "$BCV" -b {input.bam} -of bedgraph -bs 1000 -o {output.bg1000}
        "$BCV" -b {input.bam} -of bedgraph -bs 1000 --samFlagInclude 16 -o {output.bg1000m}
        "$BCV" -b {input.bam} -of bedgraph -bs 1000 --samFlagExclude 16 -o {output.bg1000p}
        """


rule chop_vector_bg4:
    input:
        bg4=[
            f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.10.bg4",
            f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.100.bg4",
            f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.1000.bg4",
        ],
    output:
        ch10=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.10.bg4.chopped.bg4",
        ch100=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.100.bg4.chopped.bg4",
        ch1000=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly.1000.bg4.chopped.bg4",
    params:
        cov_prefix=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.{{vector_id}}.vectoronly",
    wildcard_constraints:
        vector_id=_VECTOR_ID_PATTERN,
    shell:
        r"""
        # Luo 2025: convert bg4 -> bed5, chop to bin size, then bedmap scores back.
        # Requires bedops/bedmap (bedops package) inside the pipeline container.
        BOPS="${{BEDOPS_BIN:-bedops}}"
        BMAP="${{BEDMAP_BIN:-bedmap}}"
        if ! command -v "$BOPS" >/dev/null 2>&1; then
          echo "Missing required tool: bedops" >&2
          echo "Rebuild container after pulling latest containers/pipeline.def:" >&2
          echo "  apptainer build containers/pirna_pipeline.sif containers/pipeline.def" >&2
          exit 127
        fi
        if ! command -v "$BMAP" >/dev/null 2>&1; then
          echo "Missing required tool: bedmap" >&2
          echo "Rebuild container after pulling latest containers/pipeline.def:" >&2
          echo "  apptainer build containers/pirna_pipeline.sif containers/pipeline.def" >&2
          exit 127
        fi
        for bs in 10 100 1000; do
          in="{params.cov_prefix}.${{bs}}.bg4"
          out="$in.chopped.bg4"
          tmp="$(mktemp -p {RESULTS_DIR}/coverage signal.XXXXXX.bed)"
          awk -vOFS="\t" '{{ print $1, $2, $3, ".", $4 }}' "$in" > "$tmp"
          "$BOPS" --chop "$bs" "$tmp" | "$BMAP" --echo --echo-map-score - "$tmp" | sed -e 's/|/\t/g' > "$out"
          rm -f "$tmp"
        done
        test -s "{output.ch10}" && test -s "{output.ch100}" && test -s "{output.ch1000}"
        """


if EMIT_COVERAGE and TE_REGIONS:
    _TE_TAG_PATTERN = "|".join(re.escape(k) for k in TE_REGIONS.keys())

    rule te_cluster_coverage:
        input:
            UNIQUE_BAM,
        output:
            bg10=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.10.bg4",
            bg10m=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.10.Minus.bg4",
            bg10p=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.10.Plus.bg4",
            bg100=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.100.bg4",
            bg100m=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.100.Minus.bg4",
            bg100p=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.100.Plus.bg4",
            bg1000=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.1000.bg4",
            bg1000m=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.1000.Minus.bg4",
            bg1000p=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.1000.Plus.bg4",
        wildcard_constraints:
            tag=_TE_TAG_PATTERN,
        params:
            region=lambda w: normalize_te_region(TE_REGIONS[w.tag]),
        shell:
            """
            BCV="${{BAMCOVERAGE_BIN:-bamCoverage}}"
            mkdir -p {RESULTS_DIR}/coverage
            REG='{params.region}'
            "$BCV" -b {input} -of bedgraph -bs 10 --region "$REG" -o {output.bg10}
            "$BCV" -b {input} -of bedgraph -bs 10 --region "$REG" --samFlagInclude 16 -o {output.bg10m}
            "$BCV" -b {input} -of bedgraph -bs 10 --region "$REG" --samFlagExclude 16 -o {output.bg10p}
            "$BCV" -b {input} -of bedgraph -bs 100 --region "$REG" -o {output.bg100}
            "$BCV" -b {input} -of bedgraph -bs 100 --region "$REG" --samFlagInclude 16 -o {output.bg100m}
            "$BCV" -b {input} -of bedgraph -bs 100 --region "$REG" --samFlagExclude 16 -o {output.bg100p}
            "$BCV" -b {input} -of bedgraph -bs 1000 --region "$REG" -o {output.bg1000}
            "$BCV" -b {input} -of bedgraph -bs 1000 --region "$REG" --samFlagInclude 16 -o {output.bg1000m}
            "$BCV" -b {input} -of bedgraph -bs 1000 --region "$REG" --samFlagExclude 16 -o {output.bg1000p}
            """

    rule chop_te_bg4:
        input:
            bg10=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.10.bg4",
            bg100=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.100.bg4",
            bg1000=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.1000.bg4",
        output:
            ch10=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.10.bg4.chopped.bg4",
            ch100=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.100.bg4.chopped.bg4",
            ch1000=f"{RESULTS_DIR}/coverage/{SAMPLE_NAME}.{GENOME_VERSION}.{SIZE_CLASS_MER}.te.{{tag}}.1000.bg4.chopped.bg4",
        wildcard_constraints:
            tag=_TE_TAG_PATTERN,
        params:
            prefix=lambda w: te_cov_prefix(w.tag),
        shell:
            r"""
            BOPS="${{BEDOPS_BIN:-bedops}}"
            BMAP="${{BEDMAP_BIN:-bedmap}}"
            if ! command -v "$BOPS" >/dev/null 2>&1; then
              echo "Missing required tool: bedops" >&2
              exit 127
            fi
            if ! command -v "$BMAP" >/dev/null 2>&1; then
              echo "Missing required tool: bedmap" >&2
              exit 127
            fi
            for bs in 10 100 1000; do
              in="{params.prefix}.$bs.bg4"
              out="$in.chopped.bg4"
              tmp="$(mktemp -p {RESULTS_DIR}/coverage te_signal.XXXXXX.bed)"
              awk -vOFS="\t" '{{ print $1, $2, $3, ".", $4 }}' "$in" > "$tmp"
              "$BOPS" --chop "$bs" "$tmp" | "$BMAP" --echo --echo-map-score - "$tmp" | sed -e 's/|/\t/g' > "$out"
              rm -f "$tmp"
            done
            test -s "{output.ch10}" && test -s "{output.ch100}" && test -s "{output.ch1000}"
            """


rule summary_report:
    input:
        genome_bam=GENOME_BAM,
        unique_bam=UNIQUE_BAM,
        vector_bam=expand(
            RESULTS_DIR + "/mapping/" + SAMPLE_NAME + ".{size_class}.{vector_id}.vector.bam",
            size_class=SIZE_CLASS,
            vector_id=VECTOR_IDS,
        ),
        coverage=lambda wc: COVERAGE_BG if EMIT_COVERAGE else [],
    output:
        SUMMARY_TXT,
    params:
        mapq_filter=MAPQ_FILTER_UNIQUE,
        te_note=",".join(sorted(TE_REGIONS.keys())) if TE_REGIONS else "none",
        emit_coverage=EMIT_COVERAGE,
        vector_bam_list=" ".join(vector_bam_path(v) for v in VECTOR_IDS),
        vector_ids=",".join(VECTOR_IDS),
    shell:
        """
        mkdir -p {RESULTS_DIR}/reports
        {{
          echo "piRNA-seq summary (Luo 2025 piRNA-seq.md parity targets)"
          echo "sample: {SAMPLE_NAME}"
          echo "size_class: {SIZE_CLASS}"
          echo "genome: {GENOME_VERSION}"
          echo "vector_ids: {params.vector_ids}"
          echo "emit_coverage: {params.emit_coverage}"
          echo "mapq_filter_unique: {params.mapq_filter}"
          echo "te_regions: {params.te_note}"
          echo "raw_fastq: {RAW_FASTQ}"
          echo "sized_fastq: {SIZE_SELECTED_FASTQ}"
          echo "genome_bam: {input.genome_bam}"
          echo "unique_bam: {input.unique_bam}"
          echo "vector_bams: {params.vector_bam_list}"
          if [ "{params.emit_coverage}" = "True" ]; then
            echo "coverage_bedgraph: {input.coverage}"
          else
            echo "coverage_bedgraph: none"
          fi
        }} > {output}
        """
